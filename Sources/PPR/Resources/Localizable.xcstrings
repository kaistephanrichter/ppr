    "settings.excluded_tags.footer": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Tags werden in der gesamten App ausgeblendet – in der Dokumentenliste und im Filter. Ideal für systemgenerierte Workflow-Tags wie „Posteingang“ oder „Verarbeitet“."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These tags are hidden throughout the app – in the document list and in filters. Ideal for system-generated workflow tags like “Inbox” or “Processed”."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estas etiquetas se ocultan en toda la aplicación – en la lista de documentos y en los filtros. Ideal para etiquetas de flujo de trabajo generadas por el sistema, como «Bandeja de entrada» o «Procesado»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces tags sont masqués dans toute l’application – dans la liste de documents et dans les filtres. Idéal pour les tags de flux de travail générés par le système, comme « Boîte de réception » ou « Traité »."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questi tag sono nascosti in tutta l’app – nell’elenco documenti e nei filtri. Ideale per i tag di flusso di lavoro generati dal sistema, come «In arrivo» o «Elaborato»."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze tags worden in de hele app verborgen – in de documentenlijst en in de filters. Ideaal voor door het systeem gegenereerde workflow-tags zoals „Postvak IN“ of „Verwerkt“."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Te tagi są ukryte w całej aplikacji – na liście dokumentów i w filtrach. Idealne dla tagów przepływu pracy generowanych przez system, takich jak „Skrzynka odbiorcza“ czy „Przetworzono“."
          }
        }
      }
    },
