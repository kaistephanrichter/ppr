        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj token API w Ustawieniach."
          }
        }
      }
    },
    "error.unauthorized": {
      "comment": "PaperlessAPIError: 401/403 unauthorized",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTP 401/403: API-Token ungültig oder abgelaufen. In Paperless unter Profil ein neues Token erzeugen und in den Einstellungen speichern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTP 401/403: API token is invalid or expired. Generate a new token in Paperless under Profile and save it in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTP 401/403: token API inválido o caducado. Genera un nuevo token en Paperless bajo Perfil y guárdalo en Ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTP 401/403 : jeton API invalide ou expiré. Générez un nouveau jeton dans Paperless sous Profil et enregistrez-le dans les paramètres."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTP 401/403: token API non valido o scaduto. Genera un nuovo token in Paperless sotto Profilo e salvalo nelle impostazioni."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTP 401/403: API-token ongeldig of verlopen. Genereer een nieuw token in Paperless onder Profiel en sla het op in Instellingen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTP 401/403: token API jest nieprawidłowy lub wygasł. Wygeneruj nowy token w Paperless w sekcji Profil i zapisz go w Ustawieniach."
          }
        }
      }
    },
