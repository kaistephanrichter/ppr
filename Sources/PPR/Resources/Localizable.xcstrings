    "error.invalid_server_url": {
      "comment": "PaperlessAPIError: invalid server URL",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Server-URL ist ungültig. Bitte Schema angeben, z. B. https://paperless.example.com"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The server URL is not valid. Include a scheme, for example https://paperless.example.com"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La URL del servidor no es válida. Incluye un esquema, por ejemplo https://paperless.example.com"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'URL du serveur n'est pas valide. Incluez un schéma, par exemple https://paperless.example.com"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'URL del server non è valido. Includi uno schema, ad esempio https://paperless.example.com"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De server-URL is niet geldig. Voeg een schema toe, bijvoorbeeld https://paperless.example.com"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Adres URL serwera jest nieprawidłowy. Podaj schemat, np. https://paperless.example.com"
          }
        }
      }
    },
    "error.local_network_blocked": {
      "comment": "PaperlessAPIError: local network access denied",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Zugriff auf das lokale Netzwerk ist gesperrt (Fehler „Local network prohibited“). Bitte erlauben: Einstellungen → Datenschutz & Sicherheit → Lokales Netzwerk → PPR aktivieren. Falls noch kein Dialog kam: App einmal neu starten und erneut auf Status/Dokumente wechseln."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local network access is blocked (“Local network prohibited”). Please allow it: Settings → Privacy & Security → Local Network → enable PPR. If no dialog appeared yet, restart the app and switch to Status/Documents again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso a la red local está bloqueado («Local network prohibited»). Permítelo en: Ajustes → Privacidad y seguridad → Red local → activar PPR. Si no apareció ningún diálogo, reinicia la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès au réseau local est bloqué (erreur « Local network prohibited »). Veuillez l'autoriser : Réglages → Confidentialité et sécurité → Réseau local → activer PPR. Si aucune boîte de dialogue n'est apparue, redémarrez l'application."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso alla rete locale è bloccato (errore \"Local network prohibited\"). Consenti l'accesso in: Impostazioni → Privacy e sicurezza → Rete locale → abilita PPR. Se non è apparso alcun dialogo, riavvia l'app."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Toegang tot het lokale netwerk is geblokkeerd (fout \"Local network prohibited\"). Sta toe via: Instellingen → Privacy en beveiliging → Lokaal netwerk → PPR inschakelen. Als er nog geen dialoog is verschenen, herstart de app."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostęp do sieci lokalnej jest zablokowany (błąd „Local network prohibited“). Zezwól na dostęp w: Ustawienia → Prywatność i bezpieczeństwo → Sieć lokalna → włącz PPR. Jeśli nie pojawił się dialog, uruchom aplikację ponownie."
          }
        }
      }
    },
    "error.missing_credentials": {
      "comment": "PaperlessAPIError: missing API token",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte API-Token in den Einstellungen eintragen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add your API token in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade tu token API en los ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez votre jeton API dans les paramètres."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi il token API nelle impostazioni."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg uw API-token toe in Instellingen."
          }
